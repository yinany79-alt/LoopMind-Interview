# ====== Claude(京东云中转或直连)======
# Evaluator / JD Parser / Reporter 用 Claude Opus 4.8
ANTHROPIC_AUTH_TOKEN=your-anthropic-token
ANTHROPIC_BASE_URL=https://modelservice.jdcloud.com/anthropic
ANTHROPIC_OPUS_MODEL=Claude-Opus-4.8-hq[1M]

# ====== DeepSeek(可选,空则 Interviewer 回落到 Claude)======
# Interviewer / Drill-down 用 DeepSeek V4 Pro
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ====== 后端配置 ======
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173

# ====== 行为开关 ======
# true=Interviewer 也走 Claude(联调期 / 没 DeepSeek key 时)
USE_CLAUDE_FOR_INTERVIEWER=true
# 调试日志开关
DEBUG_LOG=true
