# ====== Evaluator / JD Parser / Reporter:Claude Opus(京东云中转或直连 Anthropic)======
ANTHROPIC_AUTH_TOKEN=your-claude-token
ANTHROPIC_BASE_URL=https://modelservice.jdcloud.com/anthropic
ANTHROPIC_OPUS_MODEL=Claude-Opus-4.7

# ====== Interviewer / Drill-down:小米 MiMo(Anthropic 协议)======
# 没配 MIMO_AUTH_TOKEN 时,Interviewer 自动回落到 Claude
MIMO_AUTH_TOKEN=
MIMO_BASE_URL=https://api.xiaomimimo.com/anthropic
MIMO_MODEL=mimo-v2.5-pro

# 京东云 / MiMo 中转都不支持 temperature 参数;直连 Anthropic 时可设 true
# CLAUDE_SUPPORTS_TEMPERATURE=false
# MIMO_SUPPORTS_TEMPERATURE=false

# ====== 后端配置 ======
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173
DEBUG_LOG=true
