# ====== Evaluator / JD Parser / Reporter:Mimo(优先) / Claude Opus(fallback)======
# Mimo 用 OpenAI 协议
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro

# Claude Opus 京东云中转(Mimo 没配时回落)
ANTHROPIC_AUTH_TOKEN=your-claude-token
ANTHROPIC_BASE_URL=https://modelservice.jdcloud.com/anthropic
ANTHROPIC_OPUS_MODEL=Claude-Opus-4.7

# ====== Interviewer / Drill-down:DeepSeek(优先) > Mimo > Claude ======
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 京东云中转不支持 temperature 参数
# CLAUDE_SUPPORTS_TEMPERATURE=false

# ====== 后端配置 ======
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173
DEBUG_LOG=true
